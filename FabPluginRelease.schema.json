{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/metyatech/fab-plugin-release-tools/raw/master/FabPluginRelease.schema.json",
  "title": "Fab Plugin Release Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "pluginName",
    "descriptorFile",
    "engineVersions",
    "platforms",
    "distributionModules",
    "enabledPluginDependencies",
    "publisher",
    "listingId",
    "documentationUrl",
    "supportUrl",
    "content",
    "includeDirectories",
    "includeFiles",
    "requiredPackageFiles",
    "customDistributionPaths",
    "thirdPartyLicenseSets",
    "forbiddenPackagePatterns",
    "buildLogFailPatterns"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "pluginName": { "type": "string", "pattern": "^[0-9A-Za-z][0-9A-Za-z_]*$" },
    "descriptorFile": { "$ref": "#/definitions/relativePath" },
    "engineVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^5\\.[0-9]+$" }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "const": "Win64" }
    },
    "distributionModules": { "$ref": "#/definitions/nonEmptyUniqueNames" },
    "enabledPluginDependencies": { "$ref": "#/definitions/uniqueNames" },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "copyrightNotice"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "$ref": "#/definitions/httpsUrl" },
        "copyrightNotice": { "type": "string", "minLength": 1 }
      }
    },
    "listingId": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "documentationUrl": { "$ref": "#/definitions/httpsUrl" },
    "supportUrl": { "$ref": "#/definitions/httpsUrl" },
    "content": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "packFolder"],
          "properties": {
            "mode": { "const": "pack" },
            "packFolder": { "type": "string", "pattern": "^[0-9A-Za-z][0-9A-Za-z_]*$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": { "mode": { "const": "none" } }
        }
      ]
    },
    "includeDirectories": { "$ref": "#/definitions/uniquePaths" },
    "includeFiles": { "$ref": "#/definitions/uniquePaths" },
    "requiredPackageFiles": { "$ref": "#/definitions/uniquePaths" },
    "customDistributionPaths": { "$ref": "#/definitions/uniquePaths" },
    "thirdPartyLicenseSets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["root", "files"],
        "properties": {
          "root": { "$ref": "#/definitions/relativePath" },
          "files": { "$ref": "#/definitions/uniquePaths" }
        }
      }
    },
    "forbiddenPackagePatterns": { "$ref": "#/definitions/stringArray" },
    "buildLogFailPatterns": { "$ref": "#/definitions/stringArray" }
  },
  "definitions": {
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "relativePath": { "type": "string", "minLength": 1 },
    "uniquePaths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/relativePath" }
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "uniqueNames": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "nonEmptyUniqueNames": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
